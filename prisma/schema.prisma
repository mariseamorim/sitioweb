// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Farm {
  id        String     @id @default(cuid())
  name      String
  propertyType  String?  @default("Fazenda")  // Fazenda, Sítio
  // documento: pode ser CPF ou CNPJ
  documentType  String?  // 'CPF' ou 'CNPJ'
  documentNumber String? @unique
  owner         String?  // nome do proprietário
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  animals   Animal[]
  users     User[]

  @@map("farms")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  password  String
  role      String     @default("viewer") // admin, editor, viewer
  farmId    String
  farm      Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model Animal {
  id              String     @id @default(cuid())
  code            String
  name            String
  species         String     // Vaca, Boi, Porco, Cavalo, Cachorro, Galinha, Galo, Pato, Bezero
  gender          String     // Macho, Fêmea
  birthDate       DateTime
  status          String     // Vivo, Morto, Vendido, Doente, Arrendado
  gta             String?    // Guia de Trânsito Animal
  observations    String?
  imageUrl        String?
  
  // Baixa (saída do rebanho)
  lowDate         DateTime?
  lowReason       String?    // Morto, Vendido, Consumo Próprio, Sem Alteração, Aguardando
  
  farmId          String
  farm            Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  
  milkProductions     MilkProduction[]
  veterinaryTreatments VeterinaryTreatment[]
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([farmId, code])
  @@map("animals")
}

model AnimalHistory {
  id              String     @id @default(cuid())
  animalCode      String
  animalName      String
  action          String     // criado, atualizado, deletado
  changes         String?    // JSON com mudanças
  userId          String?
  
  createdAt       DateTime   @default(now())

  @@map("animal_histories")
}

model MilkProduction {
  id              String     @id @default(cuid())
  animalId        String
  animal          Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  date            DateTime
  quantity        Float      // Quantidade em litros
  observations    String?
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("milk_productions")
}

model VeterinaryTreatment {
  id              String     @id @default(cuid())
  animalId        String
  animal          Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  startDate       DateTime
  endDate         DateTime?
  medicine        String     // Nome do medicamento
  batch           String?    // Lote
  manufacturer    String?    // Fabricante
  description     String?    // Descrição do tratamento
  observations    String?
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("veterinary_treatments")
}
